[gd_scene load_steps=7 format=3 uid="uid://ewex7q0fw3sx"]

[ext_resource type="PackedScene" uid="uid://c63op72r4rm52" path="res://levels/level_1.tscn" id="1_gfqvo"]

[sub_resource type="GDScript" id="GDScript_gfqvo"]
script/source = "extends Node

@onready var current_level = $Level_1
@onready var anim = $AnimationPlayer

var next_level : Node2D = null
var speed_color_swap = 300

var is_play_mode = false

signal cannot_move

func _ready() -> void:
	if current_level.has_method(\"initialize_level\"):
		emit_signal(\"cannot_move\",true)
		current_level.connect(\"level_changed\", handle_level_changed)
		connect_to_level_change()
		current_level.initialize_level()
		MusicManager.change_music_by_level_index(current_level.level_number)

func connect_to_level_change():
	current_level.connect(\"mode_changed\", handle_chande_mode)

func handle_level_changed(current_level_number: int):
	var next_level_number : String
	
	match current_level_number:
		1:
			next_level_number = \"2\"
		2:
			next_level_number = \"3\"
		3:
			next_level_number = \"4\"
		4:
			next_level_number = \"5\"
		5:
			next_level_number = \"6\"
		6:
			next_level_number = \"7\"
		7:
			next_level_number = \"8\"
		8:
			next_level_number = \"9\"
		9: 
			next_level_number = \"10\"
		10:
			next_level_number = \"11\"
		11:
			next_level_number = \"12\"
		12: 
			next_level_number = \"13\"
		13:
			next_level_number = \"14\"
		14:
			next_level_number = \"15\"
		15:
			next_level_number = \"16\"
		16:
			next_level_number = \"17\"
		17:
			next_level_number = \"18\"
		18:
			return
		_:
			return
	
	if !anim.is_playing():
		current_level.clean()
		current_level.stop()
		var temp = load(\"res://levels/level_\"+ next_level_number +\".tscn\")
		next_level = await temp.instantiate()
		if \"can_change_mode\" in next_level:
			next_level.can_change_mode = false
		#next_level.clean()
		call_deferred(\"add_child\",next_level)
		if current_level.has_method(\"is_is_visible\"):
			next_level.call_deferred(\"is_is_visible\", false)
		anim.play(\"Fade_in\")
		MusicManager.reduce_sound(true)
		current_level.can_change_mode = false
		for player in get_tree().get_nodes_in_group(\"Player\"):
			player.clean()
		next_level.connect(\"level_changed\", handle_level_changed)
	else:
		emit_signal(\"cannot_move\",false)

func handle_chande_mode(b : bool):
	is_play_mode = b

func _on_animation_player_animation_finished(anim_name: StringName) -> void:
	match anim_name:
		\"Fade_in\":
			current_level.clean_queue_free()
			current_level = next_level
			if current_level.has_method(\"initialize_level\"):
				current_level.initialize_level()
			next_level = null
			anim.play(\"Fade_out\")
			is_play_mode = false
			if current_level.has_method(\"is_is_visible\"):
				current_level.call_deferred(\"is_is_visible\", true)
			connect_to_level_change()
		\"Fade_out\":
			if \"can_change_mode\" in current_level:
				current_level.can_change_mode = true
				MusicManager.change_music_by_level_index(current_level.level_number)
			emit_signal(\"cannot_move\",true)
"


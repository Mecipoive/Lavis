[gd_scene load_steps=7 format=3 uid="uid://ewex7q0fw3sx"]

[ext_resource type="PackedScene" uid="uid://c63op72r4rm52" path="res://levels/level_1.tscn" id="1_gfqvo"]

[sub_resource type="GDScript" id="GDScript_gfqvo"]
script/source = "extends Node

@onready var current_level = $Level_1
@onready var anim = $AnimationPlayer
@onready var color_rect: ColorRect = $ColorRect

var next_level : Node2D = null
var speed_color_swap = 300

var is_play_mode = false

signal cannot_move

func _ready() -> void:
	emit_signal(\"cannot_move\",true)
	current_level.connect(\"level_changed\", handle_level_changed)
	connect_to_level_change()

func connect_to_level_change():
	current_level.connect(\"mode_changed\", handle_chande_mode)

func _physics_process(delta: float) -> void:
	if is_play_mode:
		color_rect.color.a8 = clamp(color_rect.color.a8 - speed_color_swap * delta, 0, 81)
	else:
		color_rect.color.a8 = clamp(color_rect.color.a8 + speed_color_swap * delta, 0, 81)
func handle_level_changed(current_level_number: int):
	var next_level_number : String
	
	match current_level_number:
		1:
			next_level_number = \"2\"
		2:
			next_level_number = \"1\"
		_:
			return
	
	if !anim.is_playing():
		var temp = load(\"res://levels/level_\"+ next_level_number +\".tscn\")
		next_level = await temp.instantiate()
		next_level.clean()
		call_deferred(\"add_child\",next_level)
		next_level.call_deferred(\"is_is_visible\", false)
		anim.play(\"Fade_in\")
		next_level.connect(\"level_changed\", handle_level_changed)
	else:
		emit_signal(\"cannot_move\",false)

func handle_chande_mode(b : bool):
	is_play_mode = b

func _on_animation_player_animation_finished(anim_name: StringName) -> void:
	match anim_name:
		\"Fade_in\":
			print(\"DG 22222\")
			current_level.queue_free()
			current_level = next_level
			next_level = null
			anim.play(\"Fade_out\")
			is_play_mode = false
			current_level.call_deferred(\"is_is_visible\", true)
			connect_to_level_change()
		\"Fade_out\":
			print(\"DG 1111\")
			emit_signal(\"cannot_move\",true)
"


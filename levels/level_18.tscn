"update": 1,
"values": ["[wave amp=2 ][font=res://assets/font/yoster.ttf][center]He is on his own path now.[/center] [/font] [/wave]", "[wave amp=2 ][font=res://assets/font/yoster.ttf][center][/center] [/font] [/wave]", "[wave amp=2 ][font=res://assets/font/yoster.ttf][center]He doesn’t need our help 
no more.[/center] [/font] [/wave]", "[wave amp=2 ][font=res://assets/font/yoster.ttf][center][/center] [/font] [/wave]", "[wave amp=2 ][font=res://assets/font/yoster.ttf][center]But trust me.[/center] [/font] [/wave]", "[wave amp=2 ][font=res://assets/font/yoster.ttf][center][/center] [/font] [/wave]", "[wave amp=2 ][font=res://assets/font/yoster.ttf][center]He will remember you.[/center] [/font] [/wave]", "[wave amp=2 ][font=res://assets/font/yoster.ttf][center][/center] [/font] [/wave]", "[wave amp=2 ][font=res://assets/font/yoster.ttf][center]Thank you for helping him[/center] [/font] [/wave]", "[wave amp=2 ][font=res://assets/font/yoster.ttf][center][/center] [/font] [/wave]", "[wave amp=2 ][font=res://assets/font/yoster.ttf][center]Now, go on your own path little shadow.[/center] [/font] [/wave]", "[wave amp=2 ][font=res://assets/font/yoster.ttf][center].[/center] [/font] [/wave]", "[wave amp=2 ][font=res://assets/font/yoster.ttf][center]I'll be close if you need me.[/center] [/font] [/wave]", "[wave amp=2 ][font=res://assets/font/yoster.ttf][center][/center] [/font] [/wave]"]
}
